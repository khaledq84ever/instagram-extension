{
  "manifest_version": 3,
  "name": "InstaGet Downloader",
  "description": "Download videos, Reels, and images from Instagram — powered by sunny-creation-production-05bc.up.railway.app",
  "version": "1.2.0",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "InstaGet Downloader"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://sunny-creation-production-05bc.up.railway.app/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*", "https://instagram.com/*"],
      "js": ["src/content.js"],
      "css": ["src/styles/inject.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "instaget@khaledq8",
      "strict_min_version": "121.0"
    }
  }
}
